    buildContext:function(){ var c="Content Type: Marketing Campaign\n"; var n=val("campaign-name"),g=val("campaign-goal"); if(n)c+="Campaign: "+n+"\n"; if(g)c+="Goal: "+g+"\n"; return c; },
