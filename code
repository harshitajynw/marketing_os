  var s2  = useState("transcript");       var ctype       = s2[0];  var setCtype       = s2[1];
  var s3  = useState("");                 var content     = s3[0];  var setContent     = s3[1];
  var s4  = useState("Thought Leadership");var tone       = s4[0];  var setTone        = s4[1];
  var s5  = useState(DEF_SEL);           var sel         = s5[0];  var setSel         = s5[1];
  var s6  = useState("peakxv");          var brandHandle = s6[0];  var setBrandHandle = s6[1];
  var s7  = useState(false);             var loading     = s7[0];  var setLoading     = s7[1];
  var s8  = useState(false);             var regenLoad   = s8[0];  var setRegenLoad   = s8[1];
  var s9  = useState("");                var error       = s9[0];  var setError       = s9[1];
  var s10 = useState({});                var edited      = s10[0]; var setEdited      = s10[1];
  var s11 = useState("summary");         var tab         = s11[0]; var setTab         = s11[1];
  var s12 = useState([]);                var hist        = s12[0]; var setHist        = s12[1];
  var s13 = useState(null);              var curId       = s13[0]; var setCurId       = s13[1];
  var s14 = useState(DEF_BRAND_PEAKXV); var brandPeakxv = s14[0]; var setBrandPeakxv = s14[1];
  var s15 = useState(DEF_BRAND_SURGE);  var brandSurge  = s15[0]; var setBrandSurge  = s15[1];
  var s16 = useState(false);            var showBrand   = s16[0]; var setShowBrand   = s16[1];
  var s17 = useState(null);             var regenSec    = s17[0]; var setRegenSec    = s17[1];
  var s18 = useState(null);             var confirmDel  = s18[0]; var setConfirmDel  = s18[1];
  var s19 = useState("");               var search      = s19[0]; var setSearch      = s19[1];
  var s20 = useState(PHRASES[0]);       var phrase      = s20[0]; var setPhrase      = s20[1];
  var s21 = useState(false);            var drawerOpen  = s21[0]; var setDrawerOpen  = s21[1];
  var s22 = useState(true);             var histLoading = s22[0]; var setHistLoading = s22[1];
  var abortRef = useRef(null);
  var fileRef  = useRef();

  var typeObj     = TYPES.find(function(t){ return t.id === ctype; });
  var isVideo     = typeObj ? typeObj.video : false;
  var visSecs     = SECTIONS.filter(function(s){ return isVideo || (s.id!=="youtube" && s.id!=="titles"); });
  var selLabels   = visSecs.filter(function(s){ return sel[s.id]; }).map(function(s){ return s.label; });
  var activeBrand = brandHandle === "surge" ? brandSurge : brandPeakxv;

  useEffect(function() {
    db.get("index").then(function(v){ if(v) setHist(v); setHistLoading(false); });
    db.get("brandPeakxv").then(function(v){ if(v) setBrandPeakxv(v); });
    db.get("brandSurge").then(function(v){  if(v) setBrandSurge(v);  });
  }, []);

  useEffect(function() {
    if (!loading) return;
    setPhrase(PHRASES[Math.floor(Math.random()*PHRASES.length)]);
    var iv = setInterval(function(){ setPhrase(PHRASES[Math.floor(Math.random()*PHRASES.length)]); }, 2800);
    return function(){ clearInterval(iv); };
  }, [loading]);

  async function callAPI(msg, sys, signal) {
    var attempt = 0;
    while (attempt < 2) {
      attempt++;
      var res;
      try {
        res = await fetch("https://api.anthropic.com/v1/messages", {
          method:"POST", signal:signal,
          headers:{"Content-Type":"application/json","x-api-key":API_KEY,"anthropic-version":"2023-06-01","anthropic-dangerous-direct-browser-access":"true"},
          body:JSON.stringify({model:MODEL,max_tokens:6000,system:sys,messages:[{role:"user",content:msg}]})
        });
      } catch(e) {
        if (e.name==="AbortError") throw e;
        if (attempt<2){ await new Promise(function(r){setTimeout(r,1500);}); continue; }
        throw new Error("Network error — check your connection.");
      }
      if (res.status===429){ if(attempt<2){await new Promise(function(r){setTimeout(r,3000);});continue;} throw new Error("Rate limited — please wait."); }
      if (!res.ok){ var eb=""; try{var ej=await res.json();eb=ej.error?ej.error.message:JSON.stringify(ej);}catch(e2){eb="HTTP "+res.status;} throw new Error("API error: "+eb); }
      var d = await res.json();
      if (d.error) throw new Error(d.error.message);
      return (d.content||[]).map(function(b){ return b.text||""; }).join("");
    }
  }

  async function generate() {
    if (!content.trim()) { setError("Please add your content first."); return; }
    if (content.trim().length < 100) { setError("Content is too short — paste at least 100 characters."); return; }
    if (!hasSelection(sel, visSecs)) { setError("Please select at least one section to generate."); return; }
    if (abortRef.current) abortRef.current.abort();
    var ctrl = new AbortController(); abortRef.current = ctrl;
    setError(""); setPhrase(PHRASES[Math.floor(Math.random()*PHRASES.length)]); setLoading(true);
    await new Promise(function(r){ requestAnimationFrame(function(){ requestAnimationFrame(r); }); });
    try {
      var bobj   = BRANDS.find(function(b){ return b.id===brandHandle; }) || BRANDS[0];
      var ctx    = "Content Type: "+(typeObj?typeObj.label:ctype)+"\nPublishing Handle: "+bobj.handle+"\n";
      var raw    = await callAPI("CONTENT:\n"+content, buildPrompt(ctype,ctx,tone,sel,activeBrand), ctrl.signal);
      var parsed = parseOut(raw);
      setEdited(parsed);
      var id       = "e"+Date.now(); setCurId(id);
      // Prefer names from the generated ABOUT line, then transcript scan, then raw text
      var fromAbout    = extractNameFromAbout(parsed.summary||"");
      var fromTranscript = extractSpeakers(content);
      var speakers = fromAbout || fromTranscript;
      var preview  = (ctype==="transcript"||ctype==="panel")
        ? (speakers || content.trim().replace(/\s+/g," ").substring(0,40)+(content.length>40?"...":""))
        : content.trim().replace(/\s+/g," ").substring(0,40)+(content.length>40?"...":"");
      var lbl      = typeObj ? typeObj.label : ctype;
      var outText  = Object.values(parsed).join(" ").substring(0,2000);
      var today    = fmtDate();
      var entry    = {id:id,type:ctype,title:preview,label:lbl,date:today,output:parsed,rawContent:content.substring(0,500),outputText:outText};
      var saved    = await db.set("entry:"+id, entry);
      var ni       = hist.concat([{id:id,type:ctype,title:preview,label:lbl,date:today,rawContent:content.substring(0,500),outputText:outText}]);
      setHist(ni);
      var idxSaved = await db.set("index", ni);
      if (!saved||!idxSaved) setError("Generated but could not save. Copy your content now.");
      var ft = visSecs.find(function(s){ return sel[s.id]; });
      setTab(ft ? ft.id : "summary"); setView("output");
    } catch(e) { if (e.name!=="AbortError") setError(e.message); }
    setLoading(false); abortRef.current = null;
  }

  async function regenFn(inst) {
    if (!regenSec) return;
    if (abortRef.current) abortRef.current.abort();
    var ctrl = new AbortController(); abortRef.current = ctrl;
    setRegenLoad(true);
    try {
      var s2 = {summary:false,linkedin:false,twitter:false,youtube:false,quotes:false,titles:false};
      s2[regenSec.id] = true;
      var bobj = BRANDS.find(function(b){ return b.id===brandHandle; }) || BRANDS[0];
      var ctx  = "Content Type: "+(typeObj?typeObj.label:ctype)+"\nPublishing Handle: "+bobj.handle+"\n";
      var raw  = await callAPI("CONTENT:\n"+content+(inst?"\n\nSPECIFIC INSTRUCTION: "+inst:""), buildPrompt(ctype,ctx,tone,s2,activeBrand), ctrl.signal);
      var parsed = parseOut(raw);
      var upd  = Object.assign({}, edited);
      if (parsed[regenSec.id]) upd[regenSec.id] = parsed[regenSec.id];
      setEdited(upd);
      if (curId){ var e=await db.get("entry:"+curId); if(e){e.output=upd; await db.set("entry:"+curId,e);} }
    } catch(e) { if (e.name!=="AbortError") setError("Regen error: "+e.message); }
    setRegenLoad(false); setRegenSec(null); abortRef.current = null;
  }

  var saveEdit = useCallback(async function(sid, nv) {
    setEdited(function(prev) {
      var upd = Object.assign({}, prev); upd[sid] = nv;
      db.get("entry:"+curId).then(function(e){ if(e){ e.output=upd; db.set("entry:"+curId,e); } });
      return upd;
    });
  }, [curId]);

  async function loadEntry(id) {
    var e = await db.get("entry:"+id); if (!e) return;
    setCtype(e.type); setCurId(id); setEdited(e.output); setTab("summary"); setView("output");
  }

  async function delEntry(id) {
    await db.del("entry:"+id);
    var ni = hist.filter(function(h){ return h.id!==id; });
    setHist(ni); await db.set("index", ni);
    if (curId===id){ setView("input"); setCurId(null); }
    setConfirmDel(null);
  }

  function doExport() {
    var md = "# Content Studio Package\nType: "+ctype+"\nGenerated: "+fmtDate()+"\n\n---\n\n";
    ["summary","linkedin","twitter","youtube","quotes","titles"].forEach(function(k){ if(edited[k]) md+="## "+k+"\n"+edited[k]+"\n\n"; });
    var b = new Blob([md],{type:"text/markdown"}); var url = URL.createObjectURL(b);
    var a = document.createElement("a"); a.href=url; a.download="content-studio-"+Date.now()+".md"; a.click();
    setTimeout(function(){ URL.revokeObjectURL(url); }, 1000);
  }

  function doCopyAll() {
    var pts = [];
    ["summary","linkedin","twitter","youtube","quotes","titles"].forEach(function(k){ if(edited[k]) pts.push(edited[k]); });
    navigator.clipboard.writeText(pts.join("\n\n---\n\n"));
  }

  var sbProps = {
    hist:hist, curId:curId, search:search, setSearch:setSearch,
    brandHandle:brandHandle, histLoading:histLoading,
    onNew:function(){ setView("input"); setCurId(null); },
    onLoad:loadEntry,
    onDelete:function(id){ setConfirmDel(id); },
    onBrand:function(){ setShowBrand(true); },
  };
  var NAV_H = 56;

  return (
    <>
      {loading && <LoadingScreen phrase={phrase} labels={selLabels} />}
      <div style={{minHeight:"100vh",background:C.g50,fontFamily:FF,WebkitFontSmoothing:"antialiased"}}>
        <div style={{height:NAV_H,background:C.white,borderBottom:"1px solid "+C.g200,display:"flex",alignItems:"center",justifyContent:"space-between",padding:"0 16px",position:"sticky",top:0,zIndex:100}}>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            {isMobile && (
              <button onClick={function(){ setDrawerOpen(true); }} style={{background:"none",border:"none",cursor:"pointer",padding:"4px 6px",display:"flex",flexDirection:"column",gap:4}}>
                <div style={{width:18,height:2,background:C.g600,borderRadius:1}} />
                <div style={{width:18,height:2,background:C.g600,borderRadius:1}} />
                <div style={{width:18,height:2,background:C.g600,borderRadius:1}} />
              </button>
            )}
            <div style={{width:32,height:32,background:"linear-gradient(135deg,"+C.p500+","+C.p700+")",borderRadius:8,display:"flex",alignItems:"center",justifyContent:"center",color:C.white,flexShrink:0,fontSize:10,fontFamily:FF,fontWeight:700,textAlign:"center",lineHeight:1.2}}>CS</div>
            <span style={{fontSize:17,fontWeight:400,color:C.g900,fontFamily:FF_SERIF}}>Content Studio</span>
          </div>
          <div style={{display:"flex",gap:6}}>
            {view==="output" && !isMobile && (
              <>
                <button onClick={doExport}  style={{padding:"6px 12px",fontSize:12,fontWeight:500,borderRadius:7,border:"1px solid "+C.g200,background:C.white,color:C.g600,cursor:"pointer",fontFamily:FF}}>Export</button>
                <button onClick={doCopyAll} style={{padding:"6px 12px",fontSize:12,fontWeight:500,borderRadius:7,border:"1px solid "+C.g200,background:C.white,color:C.g600,cursor:"pointer",fontFamily:FF}}>Copy all</button>
              </>
            )}
            {view==="output" && <button onClick={function(){ setView("input"); setCurId(null); }} style={{padding:"6px 12px",fontSize:12,fontWeight:600,borderRadius:7,border:"none",background:C.p500,color:C.white,cursor:"pointer",fontFamily:FF}}>+ New</button>}
          </div>
        </div>

        {isMobile && <Drawer open={drawerOpen} onClose={function(){ setDrawerOpen(false); }}><SidebarContent {...sbProps} onClose={function(){ setDrawerOpen(false); }} /></Drawer>}

        {isMobile ? (
          <div style={{padding:"16px"}}>
            {view==="input"
              ? <InputView ctype={ctype} setCtype={setCtype} content={content} setContent={setContent} tone={tone} setTone={setTone} sel={sel} setSel={setSel} visSecs={visSecs} loading={loading} error={error} onGenerate={generate} fileRef={fileRef} isMobile={isMobile} brandHandle={brandHandle} setBrandHandle={setBrandHandle} />
              : <OutputView edited={edited} tab={tab} setTab={setTab} visSecs={visSecs} onSaveEdit={saveEdit} onRegen={setRegenSec} onExport={doExport} onCopyAll={doCopyAll} isMobile={isMobile} />
            }
          </div>
        ) : (
          <div style={{display:"flex",maxWidth:1100,margin:"0 auto",padding:"24px 20px",gap:20,alignItems:"flex-start"}}>
            <div style={{width:220,flexShrink:0,position:"sticky",top:NAV_H+16}}><SidebarContent {...sbProps} /></div>
            <div style={{flex:1,minWidth:0}}>
              {view==="input"
                ? <InputView ctype={ctype} setCtype={setCtype} content={content} setContent={setContent} tone={tone} setTone={setTone} sel={sel} setSel={setSel} visSecs={visSecs} loading={loading} error={error} onGenerate={generate} fileRef={fileRef} isMobile={isMobile} brandHandle={brandHandle} setBrandHandle={setBrandHandle} />
                : <OutputView edited={edited} tab={tab} setTab={setTab} visSecs={visSecs} onSaveEdit={saveEdit} onRegen={setRegenSec} onExport={doExport} onCopyAll={doCopyAll} isMobile={isMobile} />
              }
            </div>
          </div>
        )}

        {showBrand && <BrandModal value={activeBrand} brandHandle={brandHandle} onSave={async function(v){ if(brandHandle==="surge"){setBrandSurge(v);await db.set("brandSurge",v);}else{setBrandPeakxv(v);await db.set("brandPeakxv",v);} }} onClose={function(){ setShowBrand(false); }} />}
        {regenSec  && <RegenModal label={regenSec.label} loading={regenLoad} onRegen={regenFn} onClose={function(){ setRegenSec(null); }} />}
        {confirmDel && <ConfirmModal onConfirm={function(){ delEntry(confirmDel); }} onCancel={function(){ setConfirmDel(null); }} />}
      </div>
    </>
  );
}
