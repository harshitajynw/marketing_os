      );
    }
    return (
      <div>
        <SecHeader label={curSec?curSec.label:""} accent={curSec?curSec.accent:C.p500} sectionId={tab} text={edited[tab]||""} />
        <Sec id={tab} accent={curSec?curSec.accent:C.p500} content={edited[tab]||""} onSave={function(v){ props.onSaveEdit(tab,v); }} />
