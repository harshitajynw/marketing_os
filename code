// ── Prompt ────────────────────────────────────────────────────────────────────
function buildPrompt(type, ctx, tone, sel, brand) {
  var isConv  = type==="transcript" || type==="panel";
  var isPanel = type==="panel";
  var t       = TYPES.find(function(x){ return x.id===type; });
  var isVideo = t ? t.video : false;
  var p = brand + "\n\nTONE: " + tone + "\nCONTEXT: " + ctx + "\n\n";
  if (isConv)  p += "Auto-detect speaker names and roles from the transcript.\n";
  if (isPanel) p += "Auto-detect all panel speakers. Quote each individually.\n";
  p += "Plain text only. No markdown, no bold, no headings.\n";
  p += "Generate ONLY the sections listed. Use EXACT section headers.\n\n";
  if (sel.summary) {
    p += "---STRATEGIC SUMMARY---\n";
    p += "ABOUT: 1-2 sentences.\n";
    p += "THEMES:\n- Theme 1\n- Theme 2\n- Theme 3\n";
    p += "FOR FOUNDERS: 1-2 sentences.\n";
    if (isConv) p += "TOP CLIPS:\n1. Title - reason\n2. Title - reason\n3. Title - reason\n4. Title - reason\n5. Title - reason\n";
    p += "\n";
  }
  if (sel.linkedin) {
    p += "---LINKEDIN POSTS---\n";
    p += "[POST 1]\n100-130 words. Strong narrative hook. 2-3 punchy takeaways. Ends with a question. @PeakXVPartners voice.\n\n";
    p += "[POST 2]\nPOINTER FORMAT: First sentence introduces the speaker and session context. Second line is a video link placeholder. Third line is 'A rundown of what you will learn:'. Then 5-6 bullet points each starting with the rocket emoji, each a specific insight. End with one punchy sign-off line.\n\n";
    p += "[POST 3]\n100-130 words. Storytelling angle. One specific moment or turning point. Personal and specific.\n\n";
  }
  if (sel.twitter) {
    p += "---X POSTS---\n";
    p += "[POST 1]\nQuote post. The single most striking quote then 1-2 lines on why it matters.\n\n";
    p += "[POST 2]\nTakeaways list. 4-5 sharp numbered points on one topic from the content.\n\n";
    p += "[POST 3]\nHot take. One bold opinionated statement. 2-3 lines max.\n\n";
    p += "[POST 4]\nStat or specific fact. Lead with the number or data point. 1-2 lines of context.\n\n";
    p += "[POST 5]\nQuestion post. Pose a question the content raises or answers. Drives replies.\n\n";
    p += "[POST 6]\nThread. 5 tweets numbered 1/ 2/ 3/ 4/ 5/. One strong idea built progressively.\n\n";
  }
  if (sel.quotes) {
    p += "---QUOTE BANK---\n";
    p += "6 quotes. Format: Quote text - Speaker name\n\n";
  }
  if (isVideo && sel.youtube) {
    p += "---YOUTUBE---\n";
    p += "TITLE 1: Direct and specific, names the speaker and core topic\n";
    p += "TITLE 2: Curiosity-driven, poses a tension or question\n";
    p += "TITLE 3: Outcome-led, what viewers will learn or gain\n";
    p += "TITLE 4: Bold or contrarian, a strong claim or surprising angle\n\n";
    p += "DESCRIPTION 1:\n3-4 sentences. Speaker credibility, what the conversation covers, why founders should watch.\n\n";
    p += "DESCRIPTION 2:\n3-4 sentences. Opens with a provocative question. 2-3 biggest ideas. Ends with a call to watch.\n\n";
  }
  if (isVideo && sel.titles) {
    p += "---TITLES AND THUMBNAILS---\n";
    p += "FULL VIDEO: Title / Thumbnail: concept\n";
    p += "CLIP 1: Title / Thumbnail: concept\n";
    p += "CLIP 2: Title / Thumbnail: concept\n";
    p += "CLIP 3: Title / Thumbnail: concept\n";
    p += "CLIP 4: Title / Thumbnail: concept\n";
    p += "CLIP 5: Title / Thumbnail: concept\n\n";
  }
  return p;
}

// ── Parse ─────────────────────────────────────────────────────────────────────
function parseOut(raw) {
  var keys = ["STRATEGIC SUMMARY","LINKEDIN POSTS","X POSTS","YOUTUBE","QUOTE BANK","TITLES AND THUMBNAILS"];
  var map  = { "STRATEGIC SUMMARY":"summary","LINKEDIN POSTS":"linkedin","X POSTS":"twitter","YOUTUBE":"youtube","QUOTE BANK":"quotes","TITLES AND THUMBNAILS":"titles" };
  var res  = {};
  for (var i=0; i<keys.length; i++) {
    var sm  = "---"+keys[i]+"---";
    var si  = raw.indexOf(sm);
    if (si===-1){ res[map[keys[i]]]=""; continue; }
    var as  = raw.indexOf("\n",si)+1;
    var ei  = raw.length;
    for (var j=i+1; j<keys.length; j++) {
      var ni = raw.indexOf("---"+keys[j]+"---",as);
      if (ni!==-1 && ni<ei) ei=ni;
    }
    res[map[keys[i]]] = raw.substring(as,ei).trim();
  }
  return res;
}

function splitPosts(text) {
  var parts = text.split(/\[POST\s*\d+\]/i);
  return parts.map(function(p){ return p.trim(); }).filter(Boolean);
}

// ── Formatter ─────────────────────────────────────────────────────────────────
function clean(line) {
  return line.replace(/\*\*(.+?)\*\*/g,"$1").replace(/\*(.+?)\*/g,"$1").replace(/^#{1,4}\s+/,"").replace(/^>\s+/,"").trim();
}

function Fmt({ text }) {
  var lines = (text||"").split("\n");
  return (
    <div>
      {lines.map(function(line,i){
        var raw = line.trim();
        var t   = clean(raw);
        if (!t) return <div key={i} style={{height:8}} />;
        if (/^[A-Z][A-Z\s\-]+:?\s*$/.test(t))
          return <div key={i} style={{fontSize:10,fontWeight:700,color:C.g400,textTransform:"uppercase",letterSpacing:"0.09em",margin:"14px 0 6px"}}>{t}</div>;
        if (/^\d+[/.]\s/.test(t)) {
          var num = t.match(/^(\d+)/)[1];
          var cnt = t.replace(/^\d+[/.]\s*/,"");
          return <div key={i} style={{display:"flex",gap:10,marginBottom:7,alignItems:"flex-start"}}>
            <span style={{fontSize:11,fontWeight:700,color:C.p500,minWidth:18,paddingTop:2}}>{num}</span>
            <span style={{fontSize:13.5,lineHeight:1.7,color:C.g700}}>{cnt}</span>
          </div>;
        }
        if (/^[-•🚀]\s/.test(raw)) {
          var b   = raw.charAt(0)==="🚀"?"🚀":"·";
          var c2  = clean(raw.replace(/^[-•🚀]\s*/,""));
          return <div key={i} style={{display:"flex",gap:9,marginBottom:6,alignItems:"flex-start"}}>
            <span style={{color:C.p400,fontSize:14,lineHeight:1.6,flexShrink:0}}>{b}</span>
            <span style={{fontSize:13.5,lineHeight:1.65,color:C.g700}}>{c2}</span>
          </div>;
        }
        if (/^[A-Za-z\s\d]+:\s.+/.test(t) && t.indexOf(":")<30) {
          var ci  = t.indexOf(":");
          return <div key={i} style={{marginBottom:7}}>
            <span style={{fontSize:11,fontWeight:700,color:C.g500,textTransform:"uppercase",letterSpacing:"0.06em"}}>{t.substring(0,ci)}</span>
            <span style={{fontSize:13,color:C.g400}}> — </span>
            <span style={{fontSize:13.5,color:C.g800}}>{t.substring(ci+1).trim()}</span>
          </div>;
        }
        if (t.charAt(0)==='"')
          return <div key={i} style={{borderLeft:"3px solid "+C.p300,padding:"8px 14px",marginBottom:10,background:C.p50,borderRadius:"0 8px 8px 0"}}>
            <span style={{fontSize:13.5,lineHeight:1.7,color:C.g800,fontStyle:"italic"}}>{t}</span>
          </div>;
        return <p key={i} style={{fontSize:13.5,lineHeight:1.75,color:C.g700,marginBottom:7}}>{t}</p>;
      })}
    </div>
  );
}

