// ── Sidebar ───────────────────────────────────────────────────────────────────
function SidebarContent(props) {
  var q = (props.search||"").toLowerCase();
  var se = useState({}); var enriched = se[0]; var setEnriched = se[1];

  useEffect(function() {
    var hist = props.hist || [];
    for (var i = 0; i < hist.length; i++) {
      var h = hist[i];
      if ((h.type==="transcript"||h.type==="panel") && !h.outputText && !enriched[h.id]) {
        (function(item){
          db.get("entry:"+item.id).then(function(entry) {
            if (!entry || !entry.output) return;
            var outText = Object.values(entry.output).join(" ").substring(0,2000);
            setEnriched(function(prev){ var n=Object.assign({},prev); n[item.id]={outputText:outText,rawContent:entry.rawContent||""}; return n; });
          });
        })(h);
      }
    }
  }, [props.hist]);

  function getTitle(item) {
    var extra   = enriched[item.id] || {};
    var outText = item.outputText || extra.outputText || "";
    var rawText = item.rawContent  || extra.rawContent || "";
    if (item.type === "transcript" || item.type === "panel") {
      var s0 = extractNameFromAbout(outText);        if (s0) return s0;
      var s1 = extractSpeakersFromSummary(outText);  if (s1) return s1;
      var s2 = extractSpeakers(rawText);             if (s2) return s2;
      return "Session — " + (item.date||"");
    }
    var generic = ["Product Launch","Article","Campaign","Announcement","launch","blog","campaign","announcement"];
    if (!item.title || generic.indexOf(item.title) !== -1) return friendlyType(item.type) + " — " + (item.date||"");
    return item.title || "Untitled";
  }

  var filtered = [];
  var allHist = props.hist || [];
  for (var i = 0; i < allHist.length; i++) {
    var h = allHist[i];
    if (!q) { filtered.push(h); continue; }
    var extra = enriched[h.id] || {};
    var blob = [h.title, h.type, h.rawContent, h.outputText, extra.outputText, extra.rawContent].filter(Boolean).join(" ").toLowerCase();
    if (blob.indexOf(q) !== -1) filtered.push(h);
  }
  filtered.reverse();

  function renderItems() {
    if (props.histLoading) return <div style={{fontSize:12,color:C.g400}}>Loading...</div>;
    if (filtered.length === 0) return <div style={{fontSize:12,color:C.g400,lineHeight:1.6}}>No entries found.</div>;
    var items = [];
    for (var i = 0; i < filtered.length; i++) {
      var item = filtered[i];
      items.push(
        <div key={item.id} onClick={(function(it){ return function(){ props.onLoad(it.id); if(props.onClose) props.onClose(); }; })(item)}
          style={{padding:"10px 12px",borderRadius:10,border:"1px solid "+(item.id===props.curId?C.p500:C.g200),background:item.id===props.curId?C.p50:C.white,marginBottom:6,cursor:"pointer",position:"relative"}}>
          <div style={{fontSize:9,fontWeight:700,color:C.p500,textTransform:"uppercase",background:C.p100,display:"inline-block",padding:"1px 6px",borderRadius:4,marginBottom:4}}>{friendlyType(item.type)}</div>
          <div style={{fontSize:12,fontWeight:600,color:C.g800,whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis",marginBottom:2,paddingRight:20}}>{getTitle(item)}</div>
          <div style={{fontSize:10,color:C.g400}}>{fmtDate(item.date)}</div>
          <button onClick={(function(id){ return function(e){ e.stopPropagation(); props.onDelete(id); }; })(item.id)}
            style={{position:"absolute",top:8,right:8,background:"none",border:"none",color:C.g300,cursor:"pointer",fontSize:14,lineHeight:1}}>x</button>
        </div>
      );
    }
    return items;
  }

  return (
    <div style={{fontFamily:FF}}>
      <button onClick={function(){ props.onNew(); if(props.onClose) props.onClose(); }}
        style={{width:"100%",padding:"9px 12px",borderRadius:10,border:"none",background:C.p500,color:C.white,fontSize:13,fontWeight:600,cursor:"pointer",marginBottom:10,fontFamily:FF,display:"flex",alignItems:"center",justifyContent:"center",gap:6}}>
        <span style={{fontSize:16}}>+</span> New content
      </button>
      <button onClick={props.onBrand}
        style={{width:"100%",padding:"7px 12px",borderRadius:8,border:"1px solid "+C.g200,background:C.white,color:C.g600,fontSize:12,fontWeight:500,cursor:"pointer",marginBottom:12,fontFamily:FF}}>
        Brand Guidelines ({props.brandHandle==="surge"?"Surge":"Peak XV"})
      </button>
      <input value={props.search} onChange={function(e){ props.setSearch(e.target.value); }} placeholder="Search history..."
        style={{width:"100%",padding:"7px 10px",border:"1.5px solid "+C.g200,borderRadius:8,fontSize:12,color:C.g900,outline:"none",background:C.g50,fontFamily:FF,boxSizing:"border-box",marginBottom:10}} />
      <div style={{fontSize:10,fontWeight:700,color:C.g400,textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:8}}>History</div>
      {renderItems()}
    </div>
  );
}

