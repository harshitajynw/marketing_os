function extractSpeakers(text) {
  if (!text) return "";
  var skip = ["Speaker","Host","Moderator","Interviewer","Guest","Question","Answer","Note","The","This","When","What","How","Why","Where","But","And","So","Now","Well","Okay","Sure","Right","Yeah","Yes","No","Hi","Hello","Thank","Thanks","Great","Good","Just","That","With","From","About","Some","They","Also","Very","Really"];
  var all = [];
  var lines = text.split("\n");
  for (var i = 0; i < lines.length; i++) {
    var m = lines[i].match(/^([A-Z][a-z]{1,14}(?:\s[A-Z][a-z]{1,14})?)[\s]*:/);
    if (m) {
      var name = m[1].trim();
      if (all.indexOf(name) === -1 && skip.indexOf(name) === -1 && name.length > 2) all.push(name);
    }
  }
  var external = [];
  for (var j = 0; j < all.length; j++) {
    var n = all[j];
    if (INTERNAL_NAMES.indexOf(n) === -1 && INTERNAL_NAMES.indexOf(n.split(" ")[0]) === -1) external.push(n);
  }
  var chosen = external.length > 0 ? external : all;
  return chosen.slice(0,2).join(", ");
}

function extractSpeakersFromSummary(outputText) {
  if (!outputText) return "";
  var patterns = [
    /(?:conversation|session|chat|sat down)\s+with\s+([A-Z][a-z]+(?:\s[A-Z][a-z]+)?)/gi,
    /featuring\s+([A-Z][a-z]+(?:\s[A-Z][a-z]+)?)/gi,
    /([A-Z][a-z]+(?:\s[A-Z][a-z]+)?)\s+(?:shares|explains|reveals|discusses)/gi,
  ];
  var names = [];
  for (var p = 0; p < patterns.length; p++) {
    var rx = patterns[p]; var m;
    while ((m = rx.exec(outputText)) !== null) {
      var name = m[1].trim();
      if (INTERNAL_NAMES.indexOf(name) === -1 && INTERNAL_NAMES.indexOf(name.split(" ")[0]) === -1 && names.indexOf(name) === -1 && names.length < 2) names.push(name);
    }
  }
  return names.join(", ");
}

