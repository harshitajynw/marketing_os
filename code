}

function parseOut(raw) {
  var keys = ["STRATEGIC SUMMARY","LINKEDIN POSTS","X POSTS","YOUTUBE","QUOTE BANK","TITLES AND THUMBNAILS"];
  var map  = {"STRATEGIC SUMMARY":"summary","LINKEDIN POSTS":"linkedin","X POSTS":"twitter","YOUTUBE":"youtube","QUOTE BANK":"quotes","TITLES AND THUMBNAILS":"titles"};
  var res  = {};
  for (var i = 0; i < keys.length; i++) {
    var sm = "---"+keys[i]+"---"; var si = raw.indexOf(sm);
    if (si === -1) { res[map[keys[i]]] = ""; continue; }
    var as = raw.indexOf("\n", si) + 1; var ei = raw.length;
    for (var j = i+1; j < keys.length; j++) { var ni = raw.indexOf("---"+keys[j]+"---", as); if (ni !== -1 && ni < ei) ei = ni; }
    res[map[keys[i]]] = raw.substring(as, ei).trim();
  }
  return res;
}

// ── Formatter ─────────────────────────────────────────────────────────────────
function cleanLine(s) {
  return s.replace(/\*\*(.+?)\*\*/g,"$1").replace(/\*(.+?)\*/g,"$1").replace(/^#{1,4}\s+/,"").replace(/^>\s*/,"").trim();
}

function Fmt(props) {
  var lines = (props.text||"").split("\n");
  var els = [];
  for (var i = 0; i < lines.length; i++) {
    var raw = lines[i].trim();
    var t   = cleanLine(raw);
    if (!t) { els.push(<div key={i} style={{height:8}} />); continue; }
    if (/^[A-Z][A-Z\s\-]+:?\s*$/.test(t)) {
      els.push(<div key={i} style={{fontSize:10,fontWeight:700,color:C.g400,textTransform:"uppercase",letterSpacing:"0.09em",margin:"14px 0 6px"}}>{t}</div>);
      continue;
    }
    if (/^\d+[/.]\s/.test(t)) {
      var num = t.match(/^(\d+)/)[1]; var cnt = t.replace(/^\d+[/.]\s*/,"");
      els.push(<div key={i} style={{display:"flex",gap:10,marginBottom:7,alignItems:"flex-start"}}>
        <span style={{fontSize:11,fontWeight:700,color:C.p500,minWidth:18,paddingTop:2}}>{num}</span>
        <span style={{fontSize:13.5,lineHeight:1.7,color:C.g700}}>{cnt}</span>
      </div>);
      continue;
    }
    if (/^[-•]\s/.test(raw) || raw.charAt(0) === "\uD83D") {
      var isRocket = raw.startsWith("🚀");
      var b   = isRocket ? "🚀" : "·";
      var c2  = cleanLine(raw.replace(/^[-•🚀]\s*/,""));
      els.push(<div key={i} style={{display:"flex",gap:9,marginBottom:6,alignItems:"flex-start"}}>
        <span style={{color:C.p500,fontSize:14,lineHeight:1.6,flexShrink:0}}>{b}</span>
        <span style={{fontSize:13.5,lineHeight:1.65,color:C.g700}}>{c2}</span>
      </div>);
      continue;
    }
    if (/^[A-Za-z\s\d]+:\s.+/.test(t) && t.indexOf(":") < 30) {
      var ci = t.indexOf(":");
      els.push(<div key={i} style={{marginBottom:7}}>
        <span style={{fontSize:11,fontWeight:700,color:C.g500,textTransform:"uppercase",letterSpacing:"0.06em"}}>{t.substring(0,ci)}</span>
        <span style={{fontSize:13,color:C.g400}}> — </span>
        <span style={{fontSize:13.5,color:C.g800}}>{t.substring(ci+1).trim()}</span>
      </div>);
      continue;
    }
    if (t.charAt(0) === '"') {
      els.push(<div key={i} style={{borderLeft:"3px solid "+C.p300,padding:"8px 14px",marginBottom:10,background:C.p50,borderRadius:"0 8px 8px 0"}}>
        <span style={{fontSize:13.5,lineHeight:1.7,color:C.g800,fontStyle:"italic"}}>{t}</span>
      </div>);
      continue;
    }
    els.push(<p key={i} style={{fontSize:13.5,lineHeight:1.75,color:C.g700,marginBottom:7}}>{t}</p>);
  }
  return <div style={{fontFamily:FF_OUT}}>{els}</div>;
}

