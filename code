function field(id,label,type,ph){ return '<div class="field"><label>'+label+'</label><input type="'+type+'" id="'+id+'" placeholder="'+ph+'" /></div>'; }
function selectField(id,label,opts){ var o=opts.map(function(x){return '<option>'+x+'</option>';}).join(""); return '<div class="field"><label>'+label+'</label><select id="'+id+'">'+o+'</select></div>'; }
function speakerRowHTML(idx){ return '<div class="speaker-row" id="srow-'+idx+'"><div class="field" style="margin:0"><label>Name</label><input type="text" placeholder="e.g. Rajan Anandan" /></div><div class="field" style="margin:0"><label>Role</label><input type="text" placeholder="e.g. MD, Peak XV" /></div>'+(idx>0?'<button class="remove-btn" onclick="removeSpeaker('+idx+')">×</button>':'<div></div>')+'</div>'; }
function val(id){ var el=document.getElementById(id); return el?el.value.trim():""; }

function selectType(btn,type){
  currentType=type;
  document.querySelectorAll(".type-btn").forEach(function(b){b.classList.remove("selected");});
  btn.classList.add("selected");
  var cfg=TYPE_CONFIG[type];
  document.getElementById("context-label").innerHTML=cfg.contextLabel+' <span>— optional</span>';
  document.getElementById("input-label").textContent=cfg.inputLabel;
  document.getElementById("main-content").placeholder=cfg.inputPlaceholder;
  document.getElementById("context-fields").innerHTML=cfg.contextHTML();
  speakerCount=1;
}
function addSpeaker(){ speakerCount++; var list=document.getElementById("speakers-list"); var div=document.createElement("div"); div.innerHTML=speakerRowHTML(speakerCount-1); list.appendChild(div.firstChild); }
function removeSpeaker(idx){ var row=document.getElementById("srow-"+idx); if(row)row.parentNode.removeChild(row); }

// ── System prompt ──────────────────────────────────────────────────────────────
function buildSystemPrompt(ctx){
  var isConv=currentType==="transcript"||currentType==="panel";
  var isPanel=currentType==="panel";
  var isVideo=!!VIDEO_TYPES[currentType];
  var base="You are Chief Content Officer at Peak XV ($9B+ VC). Content for founders and operators. Published from @PeakXVPartners.\n";
  if(isConv) base+="Open posts with 'We sat down with [Speaker]...' Peak XV is publisher, speaker is subject.\n";
  else base+="Editorial voice — Peak XV sharing insights with the founder community.\n";
  if(isPanel) base+="PANEL: Quote each speaker individually.\n";
  base+="No cliches. Specific. Insight-led.\nCONTEXT: "+ctx+"\n\n"
    +"Use EXACT headers:\n\n"
    +"---STRATEGIC SUMMARY---\n"
    +"ABOUT: 1-2 sentences.\n"
    +"THEMES:\n- Theme 1\n- Theme 2\n- Theme 3\n"
    +"FOR FOUNDERS: 1-2 sentences.\n";
  if(isConv) base+="TOP CLIPS:\n1. Title — reason\n2. Title — reason\n3. Title — reason\n4. Title — reason\n5. Title — reason\n";
  base+="\n---LINKEDIN POSTS---\n"
    +"[POST 1]\n(100-130 words. Strong hook. 2-3 takeaways. End with question.)\n\n"
    +"[POST 2]\n(100-130 words. Different angle.)\n\n"
    +"[POST 3]\n(100-130 words. Different angle.)\n\n"
    +"---X POSTS---\n"
    +"[POST 1]\n(Single. Max 280 chars.)\n\n"
    +"[POST 2]\n(Single. Max 280 chars.)\n\n"
    +"[POST 3]\n(Single. Max 280 chars.)\n\n"
    +"[POST 4]\n(Single. Max 280 chars.)\n\n"
    +"[POST 5]\n(Single. Max 280 chars.)\n\n"
    +"[POST 6]\n(Thread. 5 tweets. Numbered 1/ 2/ 3/ 4/ 5/.)\n\n"
    +"---QUOTE BANK---\n"
    +"6 quotes. Format: \"Quote\" — Speaker\n\n";
  if(isVideo){
    base+="---YOUTUBE---\n"
      +"TITLE: ...\nDESCRIPTION: 2-3 sentences.\n\n"
      +"---TITLES AND THUMBNAILS---\n"
      +"FULL VIDEO: Title / Thumbnail: concept\n"
      +"CLIP 1: Title / Thumbnail: concept\n"
      +"CLIP 2: Title / Thumbnail: concept\n"
      +"CLIP 3: Title / Thumbnail: concept\n"
      +"CLIP 4: Title / Thumbnail: concept\n"
      +"CLIP 5: Title / Thumbnail: concept\n";
  }
  return base;
}

// ── Parse ──────────────────────────────────────────────────────────────────────
function parseOutput(raw){
  var keys=["STRATEGIC SUMMARY","LINKEDIN POSTS","X POSTS","YOUTUBE","QUOTE BANK","TITLES AND THUMBNAILS"];
  var map={"STRATEGIC SUMMARY":"summary","LINKEDIN POSTS":"linkedin","X POSTS":"twitter","YOUTUBE":"youtube","QUOTE BANK":"quotes","TITLES AND THUMBNAILS":"titles"};
  var result={};
  for(var i=0;i<keys.length;i++){
    var key=keys[i]; var sm="---"+key+"---"; var si=raw.indexOf(sm); var content="";
    if(si!==-1){
      var as=raw.indexOf("\n",si)+1; var ei=raw.length;
      for(var j=i+1;j<keys.length;j++){ var nm="---"+keys[j]+"---"; var ni=raw.indexOf(nm,as); if(ni!==-1&&ni<ei)ei=ni; }
      content=raw.substring(as,ei).trim();
    }
    result[map[key]]=content;
  }
  return result;
}
function splitPosts(text){ var parts=text.split(/\[POST \d+\]/); var r=[]; for(var i=0;i<parts.length;i++){var p=parts[i].trim();if(p)r.push(p);} return r; }

// ── File ──────────────────────────────────────────────────────────────────────
function handleFile(e){ var f=e.target.files[0]; if(!f)return; var r=new FileReader(); r.onload=function(ev){document.getElementById("main-content").value=ev.target.result;document.getElementById("dz-title").textContent="Loaded: "+f.name;updateCharCount();}; r.readAsText(f); }
function handleDrop(e){ e.preventDefault(); document.getElementById("dropzone").classList.remove("drag"); var f=e.dataTransfer.files[0]; if(!f)return; var r=new FileReader(); r.onload=function(ev){document.getElementById("main-content").value=ev.target.result;document.getElementById("dz-title").textContent="Loaded: "+f.name;updateCharCount();}; r.readAsText(f); }
function updateCharCount(){ var len=document.getElementById("main-content").value.length; document.getElementById("char-count").textContent=len>0?len.toLocaleString()+" chars":""; }

// ── Generate ───────────────────────────────────────────────────────────────────
function generate(){
  var content=document.getElementById("main-content").value.trim();
  var errEl=document.getElementById("error-msg"); errEl.style.display="none";
  if(!content){showError("Please add your content first.");return;}
  var cfg=TYPE_CONFIG[currentType];
  var systemPrompt=buildSystemPrompt(cfg.buildContext());
  document.getElementById("loading-screen").style.display="flex";
  fetch("https://api.anthropic.com/v1/messages",{
    method:"POST",
    headers:{"Content-Type":"application/json","x-api-key":API_KEY,"anthropic-version":"2023-06-01","anthropic-dangerous-direct-browser-access":"true","anthropic-beta":"max-tokens-3-5-sonnet-2024-07-15"},
    body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:6000,system:systemPrompt,messages:[{role:"user",content:"CONTENT INPUT:\n"+content}]})
  })
  .then(function(res){return res.json();})
  .then(function(data){
    document.getElementById("loading-screen").style.display="none";
    if(data.error){showError("API error: "+data.error.message+" ("+data.error.type+")");return;}
    if(!data.content||!data.content.length){showError("Empty response from API. Check your API key.");return;}
    var raw=""; if(data.content){for(var i=0;i<data.content.length;i++){if(data.content[i].text)raw+=data.content[i].text;}}
    var parsed=parseOutput(raw);
    state.output=parsed; state.editing={}; state.activeTab="summary";
    var pillText=cfg.pillText();
    var pill=document.getElementById("context-pill");
    if(pillText){pill.textContent=pillText;pill.style.display="block";}
    var id=genId(); currentEntryId=id;
    var entry={id:id,type:currentType,title:pillText,date:new Date().toLocaleDateString(),output:parsed};
    saveEntry(id,entry);
    var idx=loadIndex(); idx.push({id:id,type:currentType,title:pillText,date:entry.date}); saveIndex(idx);
    showOutputView(id);
  })
  .catch(function(err){document.getElementById("loading-screen").style.display="none";showError("Network error: "+err.message+". Check your API key and internet connection.");});
}
function showError(msg){var el=document.getElementById("error-msg");el.textContent=msg;el.style.display="block";}

// ── Output ─────────────────────────────────────────────────────────────────────
function showOutputView(activeId){
  document.getElementById("input-view").style.display="none";
  document.getElementById("output-view").style.display="block";
  document.getElementById("header-output-btns").style.display="flex";
  renderHistory("history-list-output",activeId);
  renderTabs(); renderPanel();
}
function renderTabs(){
  var el=document.getElementById("tabs"); var html=""; var tabs=getTabs();
  for(var i=0;i<tabs.length;i++){ var t=tabs[i]; html+='<button class="tab-btn'+(state.activeTab===t.id?" active":"")+'" onclick="switchTab(\''+t.id+'\')">'+t.label+'</button>'; }
  el.innerHTML=html;
}
function switchTab(id){state.activeTab=id;renderTabs();renderPanel();}
function renderPanel(){
  var panel=document.getElementById("output-panel"); var tabs=getTabs(); var tab=null;
  for(var i=0;i<tabs.length;i++){if(tabs[i].id===state.activeTab){tab=tabs[i];break;}}
  if(!tab){state.activeTab=tabs[0].id;tab=tabs[0];renderTabs();}
  var html="";
  if(state.activeTab==="linkedin"||state.activeTab==="twitter"){
    var posts=splitPosts(state.output[state.activeTab]||"");
    var lbl=state.activeTab==="linkedin"?"LinkedIn Post":"X Post";
    for(var j=0;j<posts.length;j++){
      var key=state.activeTab+"_"+j;
      var v=state.editing[key]!==undefined?state.editing[key]:posts[j];
      html+=renderSection(key,lbl+" "+(j+1),v,tab.accent);
    }
  } else {
    var v2=state.editing[state.activeTab]!==undefined?state.editing[state.activeTab]:(state.output[state.activeTab]||"");
    html+=renderSection(state.activeTab,tab.label,v2,tab.accent);
  }
  html+='<div class="panel-footer"><button class="btn-sm" onclick="exportMd()">↓ Export .md</button><button class="btn-sm" onclick="copyAll()">Copy all</button></div>';
  panel.innerHTML=html;
}

function escapeHtml(s){return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");}
function escapeAttr(s){return s.replace(/\\/g,"\\\\").replace(/'/g,"\\'").replace(/\n/g,"\\n").replace(/\r/g,"");}

function formatContent(text){
  // Convert raw text into clean styled HTML
  var lines=text.split("\n");
  var html="";
  for(var i=0;i<lines.length;i++){
    var line=lines[i];
    var trimmed=line.trim();
    if(!trimmed){html+="<div style='height:10px'></div>";continue;}
    // ALL CAPS label like "CORE THEMES:" or "WHY IT MATTERS:"
    if(/^[A-Z][A-Z\s\-:]+:$/.test(trimmed)||/^[A-Z][A-Z\s]+$/.test(trimmed)){
      html+='<div style="font-size:10px;font-weight:700;color:var(--gray400);text-transform:uppercase;letter-spacing:0.09em;margin:14px 0 6px">'
        +escapeHtml(trimmed)+'</div>';
      continue;
    }
    // Numbered list: "1. ..." or "2. ..."
    if(/^\d+\.\s/.test(trimmed)){
      var content=trimmed.replace(/^\d+\.\s*/,"");
      var num=trimmed.match(/^(\d+)\./)[1];
      html+='<div style="display:flex;gap:10px;margin-bottom:7px;align-items:flex-start">'
        +'<span style="font-size:11px;font-weight:700;color:var(--p500);min-width:18px;padding-top:2px">'+num+'</span>'
        +'<span style="font-size:13.5px;line-height:1.7;color:var(--gray700)">'+escapeHtml(content)+'</span>'
        +'</div>';
      continue;
    }
    // Bullet: "- ..."
    if(/^[-•]\s/.test(trimmed)){
      var content=trimmed.replace(/^[-•]\s*/,"");
      html+='<div style="display:flex;gap:9px;margin-bottom:6px;align-items:flex-start">'
        +'<span style="color:var(--p400);font-size:14px;line-height:1.6;flex-shrink:0">·</span>'
        +'<span style="font-size:13.5px;line-height:1.65;color:var(--gray700)">'+escapeHtml(content)+'</span>'
        +'</div>';
      continue;
    }
    // Key: value line like "TITLE: ..." or "Week 1: ..."
    if(/^[A-Za-z\s]+:\s.+/.test(trimmed)&&trimmed.indexOf(":")<30){
      var colon=trimmed.indexOf(":");
      var key=trimmed.substring(0,colon);
      var val=trimmed.substring(colon+1).trim();
      html+='<div style="margin-bottom:7px">'
        +'<span style="font-size:11px;font-weight:700;color:var(--gray500);text-transform:uppercase;letter-spacing:0.06em">'+escapeHtml(key)+'</span>'
        +'<span style="font-size:13px;color:var(--gray400)"> — </span>'
        +'<span style="font-size:13.5px;color:var(--gray800)">'+escapeHtml(val)+'</span>'
        +'</div>';
      continue;
    }
    // Quote line: starts with "
    if(trimmed.charAt(0)==='"'){
      html+='<div style="border-left:3px solid var(--p300);padding:8px 14px;margin-bottom:10px;background:var(--p50);border-radius:0 8px 8px 0">'
        +'<span style="font-size:13.5px;line-height:1.7;color:var(--gray800);font-style:italic">'+escapeHtml(trimmed)+'</span>'
        +'</div>';
      continue;
    }
    // Default paragraph
    html+='<p style="font-size:13.5px;line-height:1.75;color:var(--gray700);margin-bottom:7px">'+escapeHtml(trimmed)+'</p>';
  }
  return html;
}

function renderSection(key,label,val,accent){
  var isEditing=state.editing["__edit_"+key]===true;
  var escaped=escapeHtml(val); var attrVal=escapeAttr(val);
  if(isEditing){
    return '<div class="section"><div class="sec-header"><div class="sec-title-row"><div class="accent-bar" style="background:'+accent+'"></div><span class="sec-label">'+label+'</span></div><div class="sec-actions"><button class="btn-save" onclick="saveEdit(\''+key+'\')">Save</button><button class="btn-cancel" onclick="cancelEdit(\''+key+'\')">Cancel</button></div></div><textarea class="sec-textarea" id="ta-'+key+'" rows="10">'+escaped+'</textarea></div>';
  }
  return '<div class="section"><div class="sec-header"><div class="sec-title-row"><div class="accent-bar" style="background:'+accent+'"></div><span class="sec-label">'+label+'</span></div><div class="sec-actions"><button class="btn-sm" onclick="startEdit(\''+key+'\',\''+attrVal+'\')">Edit</button><button class="btn-sm" onclick="copyText(\''+attrVal+'\')">Copy</button></div></div>'
    +'<div class="sec-content" onclick="startEdit(\''+key+'\',\''+attrVal+'\')">'+formatContent(val)+'<div class="click-hint">Click to edit</div></div></div>';
}

function startEdit(key,val){
  val=val.replace(/\\n/g,"\n").replace(/\\'/g,"'").replace(/\\\\/g,"\\");
  state.editing["__edit_"+key]=true; state.editing[key]=val; renderPanel();
  setTimeout(function(){var ta=document.getElementById("ta-"+key);if(ta)ta.focus();},50);
}
function saveEdit(key){
  var ta=document.getElementById("ta-"+key);
  if(ta){
    state.editing[key]=ta.value;
    if(key.indexOf("linkedin_")===0||key.indexOf("twitter_")===0){
      var parts=key.split("_"),base=parts[0],idx=parseInt(parts[1]);
      var posts=splitPosts(state.output[base]||""); posts[idx]=ta.value; state.output[base]=posts.join("\n\n");
    } else { state.output[key]=ta.value; }
    if(currentEntryId){ var entry=loadEntry(currentEntryId); if(entry){entry.output=state.output;saveEntry(currentEntryId,entry);} }
  }
  state.editing["__edit_"+key]=false; renderPanel();
}
function cancelEdit(key){state.editing["__edit_"+key]=false;delete state.editing[key];renderPanel();}
function copyText(val){val=val.replace(/\\n/g,"\n").replace(/\\'/g,"'").replace(/\\\\/g,"\\");navigator.clipboard.writeText(val);}
function copyAll(){
  var keys=["summary","linkedin","twitter","youtube","quotes","titles"],parts=[];
  for(var i=0;i<keys.length;i++){if(state.output[keys[i]])parts.push(state.output[keys[i]]);}
  navigator.clipboard.writeText(parts.join("\n\n---\n\n"));
}
function exportMd(){
  var cfg=TYPE_CONFIG[currentType]; var pill=cfg.pillText();
  var lines="# ContentOS — Peak XV Content Package\n**Type:** "+currentType+"\n";
  if(pill)lines+="**Subject:** "+pill+"\n";
  lines+="**Generated:** "+new Date().toLocaleDateString()+"\n\n---\n\n";
  lines+="## Strategic Summary\n"+(state.output.summary||"")+"\n\n## LinkedIn Posts\n"+(state.output.linkedin||"")+"\n\n## X / Twitter\n"+(state.output.twitter||"")+"\n\n## YouTube\n"+(state.output.youtube||"")+"\n\n## Quote Bank\n"+(state.output.quotes||"")+"\n\n## Titles and Thumbnails\n"+(state.output.titles||"");
  var blob=new Blob([lines],{type:"text/markdown"}); var a=document.createElement("a");
  a.href=URL.createObjectURL(blob); a.download="contentos-"+Date.now()+".md"; a.click();
}
function resetApp(){
  document.getElementById("input-view").style.display="block";
  document.getElementById("output-view").style.display="none";
  document.getElementById("header-output-btns").style.display="none";
  document.getElementById("context-pill").style.display="none";
  document.getElementById("main-content").value="";
  document.getElementById("char-count").textContent="";
  document.getElementById("dz-title").textContent="Drop a file here, or click to browse";
  document.getElementById("error-msg").style.display="none";
  state.output={}; state.editing={}; currentEntryId=null;
  renderHistory("history-list",null);
}

selectType(document.querySelector(".type-btn[data-type='transcript']"),"transcript");
renderHistory("history-list",null);
