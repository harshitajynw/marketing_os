  var visSecs  = props.visSecs;
  var curSec   = visSecs.find(function(s){ return s.id===tab; }) || visSecs[0];
  var isMulti  = tab === "linkedin" || tab === "twitter";
  var posts    = isMulti ? splitPosts(edited[tab]||"") : [];

  function SecHeader(sp) {
    return (
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8,flexWrap:"wrap",gap:6}}>
