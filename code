  if (sel.twitter) {
    p += "---X POSTS---\n[POST 1]\nQuote post. Most striking quote then 1-2 lines on why it matters.\n\n[POST 2]\nTakeaways list. 4-5 sharp numbered points.\n\n[POST 3]\nHot take. One bold opinionated statement. 2-3 lines.\n\n[POST 4]\nStat or specific fact. Lead with the number. 1-2 lines context.\n\n[POST 5]\nQuestion post. Drives replies. 1-2 lines.\n\n[POST 6]\nThread. 5 tweets numbered 1/ 2/ 3/ 4/ 5/.\n\n";
  }
  if (sel.quotes) p += "---QUOTE BANK---\n6 quotes. Format: Quote text - Speaker name\n\n";
  if (isVideo && sel.youtube) {
    p += "---YOUTUBE---\nTITLE 1: Direct and specific\nTITLE 2: Curiosity-driven\nTITLE 3: Outcome-led\nTITLE 4: Bold or contrarian\n\nDESCRIPTION 1:\n3-4 sentences. Speaker credibility, what it covers, why founders should watch.\n\nDESCRIPTION 2:\n3-4 sentences. Opens with provocative question. 2-3 biggest ideas. Call to watch.\n\n";
